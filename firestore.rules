rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function businessEmailMatchesAuth() {
      return resource.data.keys().hasAll(['email'])
        && resource.data.email is string
        && request.auth.token.email == resource.data.email;
    }

    function businessUnclaimed() {
      return !('ownerUid' in resource.data)
        || resource.data.ownerUid == null
        || resource.data.ownerUid == '';
    }

    /* Dueño del negocio (documento businesses/{businessId}). */
    function businessOwnerUid(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerUid;
    }

    function isBusinessOwner(businessId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/businesses/$(businessId))
        && businessOwnerUid(businessId) == request.auth.uid;
    }

    match /businesses/{businessId} {
      /* Crear: dueño explícito (hasAll sobre keys fallaba en algunos payloads con FieldValue). */
      allow create: if request.auth != null
        && 'ownerUid' in request.resource.data
        && request.resource.data.ownerUid == request.auth.uid;

      allow read: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid
        || (businessEmailMatchesAuth() && businessUnclaimed())
      );

      allow update: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid
        || (
          businessEmailMatchesAuth()
          && businessUnclaimed()
          && request.resource.data.ownerUid == request.auth.uid
        )
      );

      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;

      match /leads/{leadId} {
        // Public: customers submit leads without signing in (validated fields only).
        allow create: if
          request.resource.data.keys().hasAll([
            'customerName',
            'phone',
            'address',
            'service',
            'description',
            'status',
            'estimatedPrice',
            'createdAt'
          ])
          && request.resource.data.status == 'new'
          && request.resource.data.estimatedPrice == 0;

        allow read, update, delete: if isBusinessOwner(businessId);
      }

      match /jobs/{jobId} {
        allow read, write: if isBusinessOwner(businessId);
      }

      match /campaigns/{campaignId} {
        allow read, write: if isBusinessOwner(businessId);
      }

      match /clients/{clientId} {
        allow read, write: if isBusinessOwner(businessId);
      }

      match /teamMembers/{memberId} {
        allow read, write: if isBusinessOwner(businessId);
      }

      /* Jornada / sesiones de trabajo (Equipo). Antes no existía regla → denegaba todo. */
      match /teamSessions/{sessionId} {
        allow read, create, update: if isBusinessOwner(businessId);
        allow delete: if isBusinessOwner(businessId);
      }

      /* Centro de Control Maya — WhatsApp: una conversación por número (doc id = phoneNumber). */
      match /conversations/{phoneNumber} {
        allow read, write: if isBusinessOwner(businessId);

        match /messages/{messageId} {
          allow read, write: if isBusinessOwner(businessId);
        }
      }

      /* Pedidos (incl. workStatus, totalLabor*, lastWorkedAt para Equipo). */
      match /orders/{orderId} {
        allow read, write: if isBusinessOwner(businessId);
      }

      /* Recibo compartible (solo lectura pública por id opaco; sin datos internos). */
      match /publicReceipts/{receiptId} {
        allow get: if true;
        allow list: if false;

        function publicReceiptSafeWrite() {
          return !('expenses' in request.resource.data)
            && !('netProfit' in request.resource.data)
            && !('laborCost' in request.resource.data)
            && !('labor' in request.resource.data)
            && !('notes' in request.resource.data)
            && !('totalLaborHours' in request.resource.data)
            && !('totalLaborUsd' in request.resource.data)
            && request.resource.data.receiptId == receiptId;
        }

        allow create, update: if request.auth != null
          && isBusinessOwner(businessId)
          && publicReceiptSafeWrite();

        allow delete: if request.auth != null && isBusinessOwner(businessId);
      }

      match /finance/{transactionId} {
        allow read, write: if isBusinessOwner(businessId);
      }

      /* Gastos fijos mensuales (YourColor / configuración por negocio). */
      match /fixedExpenses/{expenseId} {
        allow read, write: if isBusinessOwner(businessId);
      }

      /* Ajustes por negocio (p. ej. recibo PDF en Pedidos). */
      match /settings/{settingId} {
        allow read, write: if isBusinessOwner(businessId);
      }

      /* Calendario global (header, pedidos, Maya): eventos por negocio. Dueño = ownerUid en el doc businesses/{id}. */
      match /calendar/{eventId} {
        allow read, write: if isBusinessOwner(businessId);
      }

      /* Historial del Chat IA del panel (Maya): un doc por usuario dueño. */
      match /internalChatHistory/{userId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId
          && isBusinessOwner(businessId);
      }

      /* Centro de Diagnóstico interno (solo dueño/admin del negocio). */
      match /diagnostics/{issueId} {
        allow read, write: if isBusinessOwner(businessId);
      }
    }

    /* Nuevo modelo multi-category por usuario: users/{uid}/categories/{categoryId}/... */
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /yourcolor/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /workspaces/{workspaceId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        match /categories/{categoryId} {
          allow read, write: if request.auth != null && request.auth.uid == uid;

          match /{document=**} {
            allow read, write: if request.auth != null && request.auth.uid == uid;
          }
        }
      }

      match /categories/{categoryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        match /{document=**} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }
    }
  }
}
